{
  "manifest_version": 3,
  "name": "AI Job Autofill",
  "version": "1.0",
  "description": "Autofill job applications using AI profile",

  "permissions": ["storage", "activeTab", "scripting"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
   "host_permissions": [
  "http://127.0.0.1:8000/*"
]

}